<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ================= HEADER ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="40dp"
            android:paddingBottom="20dp"
            android:background="@drawable/header_bg">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@mipmap/ic_launcher_round"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Fraud Shield"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI-Powered Call and SMS Protection"
                android:textColor="#E8F5E9"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- STATUS CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/statusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#DFF2E1"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protection Status"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#2E7D32"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical">

                        <!-- ONLY ONE SHIELD -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛡"
                            android:textSize="22sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:id="@+id/resultText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Protection Active"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20"/>

                        <!-- RIGHT SHIELD -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛡"
                            android:textSize="22sp"
                            android:layout_marginStart="6dp"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- MODE CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:backgroundTint="#424242"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Detection Mode"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/modeSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/modeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Demo Mode"
                        android:textColor="#DDDDDD"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CALL HISTORY -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/callHistoryBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="VIEW CALL HISTORY"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="14dp"
                android:backgroundTint="#2F6FB2"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_call"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="#FFFFFF"/>

            <!-- SMS HISTORY -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/smsHistoryBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="VIEW SMS HISTORY"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="14dp"
                android:backgroundTint="#2E7D32"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_dialog_email"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="#FFFFFF"/>

            <!-- URL HISTORY -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewUrlHistoryBtn"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="VIEW URL HISTORY"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#EF6C00"
                app:cornerRadius="30dp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="#FFFFFF"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>