<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B1F">

    <!-- 🔥 GLOW CONTAINER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glow_container"
        android:padding="16dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard > View SMS"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <!-- SAFE CARD (GREEN) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/gradient_green"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✔"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/safeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe SMS"
                    android:textSize="16sp"
                    android:textColor="#E0F2F1"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- SPAM CARD (ORANGE) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/gradient_orange"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/spamCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spam SMS"
                    android:textSize="16sp"
                    android:textColor="#FFF3E0"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- SCAM CARD (PURPLE) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/gradient_purple"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎣"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/scamCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scam SMS"
                    android:textSize="16sp"
                    android:textColor="#E1BEE7"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- PHISHING CARD (RED) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/gradient_red"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚨"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/phishingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phishing SMS"
                    android:textSize="16sp"
                    android:textColor="#FFCDD2"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>